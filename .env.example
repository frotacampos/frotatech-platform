# LumiCity local environment template

# App/runtime
VITE_APP_ENV=local

# API provider mode:
# base44 = modo atual, usando Base44 internamente nos providers
# mock = demo/offline com dados locais ficticios
# http = backend proprio futuro via FastAPI
# Em dominios *.frotatech.dev.br, o frontend forca http para producao.
# Ainda assim, configure explicitamente VITE_API_MODE=http na Vercel.
VITE_API_MODE=http
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
# Legacy compatibility only. Prefer VITE_API_BASE_URL.
URL_BASE_API_VITE=

# Current Base44 runtime
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_API_URL=
VITE_BASE44_FUNCTIONS_VERSION=

# Future first-party API, planned for Sprint 2+
VITE_LUMICITY_API_URL=
VITE_AUTH_MODE=base44

# Future AI gateway. Do not expose provider secrets in Vite variables.
VITE_OPENAI_ENABLED=false
VITE_AI_MODE=base44
VITE_AI_API_URL=

# Future storage abstraction
VITE_STORAGE_MODE=base44
VITE_STORAGE_PUBLIC_URL=

# Local development helpers
VITE_ENABLE_LOCAL_MOCKS=false
